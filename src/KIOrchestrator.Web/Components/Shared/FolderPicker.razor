@using KIOrchestrator.Web.Services
@inject FileSystemService FileSystem

<div class="folder-picker-overlay" @onclick="Cancel">
    <div class="folder-picker" @onclick:stopPropagation="true">
        <div class="fp-header">
            <h3>Verzeichnis auswaehlen</h3>
            <button class="fp-close" @onclick="Cancel">X</button>
        </div>

        <div class="fp-path-bar">
            <button class="fp-nav-btn" @onclick="GoUp" disabled="@(currentPath == null)" title="Uebergeordneter Ordner">^</button>
            <input class="fp-path-input" @bind="manualPath" @bind:event="oninput"
                   @onkeydown="OnPathKeyDown" placeholder="Pfad eingeben..." />
            <button class="fp-nav-btn" @onclick="GoToManualPath" title="Zum Pfad navigieren">-></button>
            <button class="fp-nav-btn fp-new-folder" @onclick="ShowNewFolderInput" disabled="@(currentPath == null)" title="Neuer Ordner">+</button>
        </div>

        @if (showNewFolder)
        {
            <div class="fp-new-folder-bar">
                <input class="fp-new-folder-input" @bind="newFolderName" @bind:event="oninput"
                       @onkeydown="OnNewFolderKeyDown" placeholder="Ordnername..." @ref="newFolderInputRef" />
                <button class="fp-nav-btn" @onclick="CreateNewFolder" disabled="@(string.IsNullOrWhiteSpace(newFolderName))">OK</button>
                <button class="fp-nav-btn" @onclick="CancelNewFolder">X</button>
            </div>
        }

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="fp-error">@errorMessage</div>
        }

        <div class="fp-content">
            @if (currentPath == null)
            {
                @* Drive list *@
                @foreach (var drive in drives)
                {
                    <div class="fp-item fp-drive" @onclick="() => NavigateTo(drive.Name)">
                        <span class="fp-icon">[D]</span>
                        <span class="fp-name">@drive.Label</span>
                        <span class="fp-size">@FormatSize(drive.FreeSpace) frei</span>
                    </div>
                }
            }
            else
            {
                @if (directories.Count == 0)
                {
                    <div class="fp-empty">Keine Unterverzeichnisse</div>
                }
                else
                {
                    @foreach (var dir in directories)
                    {
                        <div class="fp-item @(dir.FullPath == selectedPath ? "fp-selected" : "")"
                             @onclick="() => SelectDirectory(dir)"
                             @ondblclick="() => NavigateTo(dir.FullPath)">
                            <span class="fp-icon">@(dir.HasChildren ? "[+]" : "[ ]")</span>
                            <span class="fp-name">@dir.Name</span>
                        </div>
                    }
                }
            }
        </div>

        <div class="fp-footer">
            <span class="fp-selected-path" title="@GetDisplayPath()">@GetDisplayPath()</span>
            <div class="fp-actions">
                <button class="btn-secondary" @onclick="Cancel">Abbrechen</button>
                <button class="btn-primary" @onclick="Confirm" disabled="@(string.IsNullOrEmpty(GetDisplayPath()))">Auswaehlen</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public string? InitialPath { get; set; }
    [Parameter] public EventCallback<string> OnSelected { get; set; }
    [Parameter] public EventCallback OnCancelled { get; set; }

    private List<DriveEntry> drives = [];
    private List<DirectoryEntry> directories = [];
    private string? currentPath;
    private string? selectedPath;
    private string manualPath = string.Empty;
    private string? errorMessage;
    private bool showNewFolder;
    private string newFolderName = string.Empty;
    private ElementReference newFolderInputRef;

    protected override void OnInitialized()
    {
        drives = FileSystem.GetDrives();

        if (!string.IsNullOrEmpty(InitialPath) && FileSystem.DirectoryExists(InitialPath))
        {
            currentPath = InitialPath;
            selectedPath = InitialPath;
            manualPath = InitialPath;
            LoadDirectories();
        }
    }

    private void NavigateTo(string path)
    {
        errorMessage = null;
        currentPath = path;
        selectedPath = path;
        manualPath = path;
        LoadDirectories();
    }

    private void SelectDirectory(DirectoryEntry dir)
    {
        selectedPath = dir.FullPath;
        manualPath = dir.FullPath;
    }

    private void GoUp()
    {
        if (currentPath == null) return;
        var parent = FileSystem.GetParentPath(currentPath);
        if (parent != null)
        {
            NavigateTo(parent);
        }
        else
        {
            // Back to drive list
            currentPath = null;
            selectedPath = null;
            manualPath = string.Empty;
            directories = [];
        }
    }

    private void GoToManualPath()
    {
        errorMessage = null;
        var path = manualPath.Trim();
        if (string.IsNullOrEmpty(path)) return;

        if (FileSystem.DirectoryExists(path))
        {
            NavigateTo(path);
        }
        else
        {
            errorMessage = "Verzeichnis existiert nicht.";
        }
    }

    private void OnPathKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            GoToManualPath();
        }
    }

    private void LoadDirectories()
    {
        try
        {
            directories = FileSystem.GetDirectories(currentPath!);
        }
        catch (UnauthorizedAccessException)
        {
            errorMessage = "Zugriff verweigert.";
            directories = [];
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            directories = [];
        }
    }

    private string GetDisplayPath()
    {
        return selectedPath ?? currentPath ?? string.Empty;
    }

    private async Task Confirm()
    {
        var path = GetDisplayPath();
        if (!string.IsNullOrEmpty(path))
        {
            await OnSelected.InvokeAsync(path);
        }
    }

    private async Task Cancel()
    {
        await OnCancelled.InvokeAsync();
    }

    private void ShowNewFolderInput()
    {
        showNewFolder = true;
        newFolderName = string.Empty;
        errorMessage = null;
    }

    private void CancelNewFolder()
    {
        showNewFolder = false;
        newFolderName = string.Empty;
    }

    private void CreateNewFolder()
    {
        if (currentPath == null || string.IsNullOrWhiteSpace(newFolderName)) return;
        errorMessage = null;

        try
        {
            var created = FileSystem.CreateDirectory(currentPath, newFolderName.Trim());
            showNewFolder = false;
            newFolderName = string.Empty;
            LoadDirectories();
            selectedPath = created.FullPath;
            manualPath = created.FullPath;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void OnNewFolderKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            CreateNewFolder();
        else if (e.Key == "Escape")
            CancelNewFolder();
    }

    private static string FormatSize(long bytes)
    {
        if (bytes >= 1_073_741_824) return $"{bytes / 1_073_741_824.0:F1} GB";
        if (bytes >= 1_048_576) return $"{bytes / 1_048_576.0:F0} MB";
        return $"{bytes / 1024.0:F0} KB";
    }
}
